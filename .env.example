# Webapp backend settings (prefix FH_). Copy to .env for local/prod use.

# Shared-secret gate. Empty = open API (dev only). Set a strong value in prod.
FH_AUTH_SECRET=

# SQLite parcel cache (seeded by `python -m server.jobs.refresh`).
FH_DB_PATH=data/webapp.sqlite

# Built SPA directory served at / (set when serving prod-like from the API).
FH_SPA_DIR=frontend/dist

# Comp analysis window (months of sale history).
FH_MONTHS_BACK=24

# CORS + per-IP rate limits.
FH_CORS_ORIGINS=*
FH_RATE_LIMIT=120/minute
FH_RATE_LIMIT_SEARCH=300/minute
